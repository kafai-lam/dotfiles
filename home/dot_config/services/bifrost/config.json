{
  "$schema": "https://www.getbifrost.ai/schema",
  "client": {
    "allowed_headers": ["*"],
    "allowed_origins": ["*"],
    "drop_excess_requests": false,
    "enable_logging": true
  },
  "config_store": {
    "enabled": true,
    "type": "sqlite",
    "config": {
      "path": "/tmp/config.db"
    }
  },
  "logs_store": {
    "enabled": true,
    "type": "sqlite",
    "config": {
      "path": "/app/data/log.db"
    }
  },
  "providers": {
    "openai": {
      "network_config": {
        "allow_private_network": true,
        "base_url": "http://cli-proxy-api:8317"
      },
      "send_back_raw_request": true,
      "send_back_raw_response": true,
      "keys": [
        {
          "name": "OPENAI_API_KEY_auto_detected",
          "value": "env.OPENAI_API_KEY",
          "models": [
            "codex-auto-review",
            "gpt-5.3-codex",
            "gpt-5.4-mini",
            "gpt-5.4",
            "gpt-5.5",
            "gpt-image-2"
          ],
          "weight": 1
        }
      ]
    },
    "mistral": {
      "concurrency_and_buffer_size": {
        "concurrency": 1,
        "buffer_size": 1000
      },
      "send_back_raw_request": true,
      "send_back_raw_response": true,
      "keys": [
        {
          "name": "MISTRAL_API_KEY_auto_detected",
          "value": "env.MISTRAL_API_KEY",
          "models": [
            "devstral-2512",
            "mistral-small-latest",
            "mistral-medium-3.5"
          ],
          "weight": 1.0
        }
      ]
    },
    "opencode": {
      "custom_provider_config": {
        "base_provider_type": "openai",
        "allowed_requests": {
          "list_models": true,
          "text_completion": true,
          "text_completion_stream": true,
          "chat_completion": true,
          "chat_completion_stream": true,
          "responses": true,
          "responses_stream": true,
          "embedding": true,
          "speech": true,
          "speech_stream": true,
          "transcription": true,
          "transcription_stream": true
        }
      },
      "network_config": {
        "base_url": "https://opencode.ai/zen"
      },
      "send_back_raw_request": true,
      "send_back_raw_response": true,
      "keys": [
        {
          "name": "OPENCODE_API_KEY_auto_detected",
          "value": "env.OPENCODE_API_KEY",
          "models": [
            "deepseek-v4-flash-free",
            "mimo-v2.5-free",
            "north-mini-code-free",
            "nemotron-3-ultra-free"
          ],
          "weight": 1.0
        }
      ]
    }
  }
}
