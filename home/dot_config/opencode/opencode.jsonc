{
  "$schema": "https://opencode.ai/config.json",
  "theme": "github",
  "model": "bifrost/deepseek-v4-flash-free",
  "small_model": "bifrost/devstral-2512",
  "autoupdate": false,
  "provider": {
    "bifrost": {
      "name": "Bifrost",
      "npm": "@ai-sdk/openai-compatible",
      "options": {
        "baseURL": "http://localhost:8080/openai",
      },
      "models": {
        "deepseek-v4-flash-free": { "name": "DeepSeek V4 Flash" },
        "devstral-2512": { "name": "Devstral 2" },
        "mistral-small-latest": { "name": "Mistral Small 4" },
        "mistral-medium-3.5": { "name": "Mistral Medium 3.5" },
      },
    },
  },
}
