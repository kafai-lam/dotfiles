        "mistral/mistral-small-2603": { "name": "Mistral Small 4" },
        "mistral/mistral-large-latest": { "name": "Mistral Large 3" },
        "opencode/hy3-preview-free": { "name": "Hy3 Preview" },
        "opencode/minimax-m2.5-free": { "name": "MiniMax M2.5" },
        "opencode/nemotron-3-super-free": { "name": "Nemotron 3 Super" },
      },
    },
  },
