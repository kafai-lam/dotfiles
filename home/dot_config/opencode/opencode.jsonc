{
  "$schema": "https://opencode.ai/config.json",
  "theme": "github",
  "provider": {
    "bifrost": {
      "name": "Bifrost",
      "npm": "@ai-sdk/openai-compatible",
      "options": {
        "baseURL": "http://bifrost.orb.local/openai"
      },
      "models": {
        "mistral/codestral-latest": {
          "name": "Codestral"
        },
        "mistral/devstral-2512": {
          "name": "Devstral"
        },
        "mistral/ministral-14b-latest": {
          "name": "Ministral"
        },
        "mistral/mistral-large-latest": {
          "name": "Mistral Large"
        },
        "opencode/big-pickle": {
          "name": "OpenCode Zen: Big Pickle"
        },
        "opencode/glm-4.7-free": {
          "name": "OpenCode Zen: GLM 4.7"
        },
        "opencode/grok-code": {
          "name": "OpenCode Zen: Grok Code"
        },
        "opencode/minimax-m2.1-free": {
          "name": "OpenCode Zen: MiniMax 2.1"
        }
      }
    }
  },
  "model": "bifrost/mistral/devstral-2512",
  "autoupdate": false
}
