{
  "$schema": "https://opencode.ai/config.json",
  "theme": "github",
  "model": "bifrost/opencode/grok-code",
  "small_model": "bifrost/mistral/labs-devstral-small-2512",
  "autoupdate": false,
  "provider": {
    "bifrost": {
      "name": "Bifrost",
      "npm": "@ai-sdk/openai-compatible",
      "options": {
        "baseURL": "http://bifrost.orb.local/openai",
      },
      "models": {
        "mistral/codestral-latest": {
          "name": "Codestral",
        },
        "mistral/devstral-2512": {
          "name": "Devstral 2",
        },
        "mistral/labs-devstral-small-2512": {
          "name": "Devstral Small 2",
        },
        "mistral/ministral-14b-latest": {
          "name": "Ministral",
        },
        "mistral/mistral-large-latest": {
          "name": "Mistral Large",
        },
        "opencode/big-pickle": {
          "name": "Big Pickle",
        },
        "opencode/glm-4.7-free": {
          "name": "GLM 4.7",
        },
        "opencode/gpt-5-nano": {
          "name": "GPT 5 Nano",
        },
        "opencode/grok-code": {
          "name": "Grok Code Fast 1",
        },
        "opencode/minimax-m2.1-free": {
          "name": "MiniMax M2.1",
        },
      },
    },
  },
}
